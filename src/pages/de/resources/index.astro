---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="Ressourcen" description="Tipps zur Familienorganisation, Elternratgeber und Leitfäden vom Eazy.Family-Team." lang="de">
  <div style="max-width: 56rem; margin: 0 auto; padding: 8rem 1.25rem 4rem;">
    <div style="text-align: center; margin-bottom: 4rem;">
      <h1 style="font-size: clamp(1.875rem, 5vw, 2.75rem); font-weight: 800; margin-bottom: 1rem;"><span class="grad-text">Ressourcen</span></h1>
      <p style="font-size: 1rem; color: var(--text-secondary); max-width: 30rem; margin: 0 auto;">Ratgeber, Tipps und Werkzeuge, damit Ihre Familie aufblüht.</p>
    </div>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.5rem;">
      <a href="/de/resources/blog" style="text-decoration: none;" class="card" style="display: block; border-radius: 1.25rem; padding: 2rem; transition: opacity 0.15s;">
        <div style="font-size: 2rem; margin-bottom: 1rem;">✍️</div>
        <h2 style="font-size: 1.125rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.5rem;">Blog</h2>
        <p style="font-size: 0.875rem; color: var(--text-secondary); line-height: 1.6;">Tipps zur Familienorganisation, App-Ratgeber und Einblicke vom Eazy.Family-Team.</p>
      </a>
      <a href="/resources/parenting" style="text-decoration: none;" class="card" style="display: block; border-radius: 1.25rem; padding: 2rem; transition: opacity 0.15s;">
        <div style="font-size: 2rem; margin-bottom: 1rem;">👨‍👩‍👧‍👦</div>
        <h2 style="font-size: 1.125rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.5rem;">Eltern-Ressourcen</h2>
        <p style="font-size: 0.875rem; color: var(--text-secondary); line-height: 1.6;">Kuratierte Ratgeber und Werkzeuge für moderne Eltern im Familienalltag.</p>
      </a>
    </div>
  </div>
</Layout>
