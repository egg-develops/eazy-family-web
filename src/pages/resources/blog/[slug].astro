---
import Layout from '../../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout
  title={post.data.title}
  description={post.data.description}
  lang={post.data.lang}
  article={{
    headline: post.data.title,
    datePublished: post.data.pubDate.toISOString(),
    author: post.data.author,
  }}
  langSwitcherOverride={{
    en: '/resources/blog',
    de: '/de/resources/blog',
    fr: '/fr/resources/blog',
    it: '/it/resources/blog',
  }}
>

  <article style="max-width: 44rem; margin: 0 auto; padding: 8rem 1.25rem 4rem;">

    <!-- Breadcrumb -->
    <div style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 2rem;">
      <a href="/resources" style="color: var(--text-muted); text-decoration: none;">Resources</a> /
      <a href="/resources/blog" style="color: var(--text-muted); text-decoration: none;"> Blog</a> /
    </div>

    <!-- Tags -->
    <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.25rem;">
      {post.data.tags.map((tag: string) => (
        <span style="font-size: 0.6875rem; padding: 0.25rem 0.75rem; border-radius: 9999px; background: hsl(270 50% 18%); color: hsl(270 60% 80%); font-weight: 500;">{tag}</span>
      ))}
    </div>

    <!-- Title -->
    <h1 style="font-size: clamp(1.625rem, 4vw, 2.25rem); font-weight: 800; color: var(--text-primary); line-height: 1.25; margin-bottom: 1rem;">{post.data.title}</h1>

    <!-- Meta -->
    <div style="display: flex; align-items: center; gap: 1rem; font-size: 0.8125rem; color: var(--text-muted); margin-bottom: 2.5rem; padding-bottom: 2rem; border-bottom: 1px solid hsl(270 40% 16%);">
      <span>{post.data.author}</span>
      <span>·</span>
      <time>{post.data.pubDate.toLocaleDateString('en-CH', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
    </div>

    <!-- Content -->
    <div class="prose" style="font-size: 1rem;">
      <Content />
    </div>

    <!-- CTA -->
    <div class="card" style="text-align: center; margin-top: 4rem; border-radius: 1.25rem; padding: 2.5rem 2rem;">
      <h3 style="font-size: 1.25rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.625rem;">Ready to organize your family?</h3>
      <p style="font-size: 0.875rem; color: var(--text-secondary); margin-bottom: 1.5rem;">Eazy.Family is free to start. No download required.</p>
      <a href="https://app.eazy.family/onboarding" class="btn-primary">Get Started Free</a>
    </div>

  </article>

</Layout>

<style>
  .prose :global(h2) { font-size: 1.375rem; font-weight: 700; margin: 2rem 0 0.75rem; }
  .prose :global(h3) { font-size: 1.125rem; font-weight: 600; margin: 1.5rem 0 0.5rem; }
  .prose :global(p) { margin-bottom: 1.25rem; }
  .prose :global(ul), .prose :global(ol) { padding-left: 1.5rem; margin-bottom: 1.25rem; }
  .prose :global(li) { margin-bottom: 0.375rem; }
  .prose :global(table) { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.875rem; }
  .prose :global(th) { padding: 0.5rem 0.75rem; text-align: left; border-bottom: 1px solid hsl(270 40% 22%); color: var(--text-primary); font-weight: 600; }
  .prose :global(td) { padding: 0.5rem 0.75rem; border-bottom: 1px solid hsl(270 40% 14%); color: var(--text-secondary); }
  .prose :global(strong) { color: var(--text-primary); font-weight: 600; }
  .prose :global(a) { color: var(--purple); }
</style>
