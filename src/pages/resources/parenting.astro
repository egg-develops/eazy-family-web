---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Parenting Resources" description="Curated parenting guides, tools, and reading for modern families navigating busy lives in Switzerland and beyond.">

  <div style="max-width: 48rem; margin: 0 auto; padding: 8rem 1.25rem 4rem;">

    <div style="margin-bottom: 3rem;">
      <div style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.5rem;">
        <a href="/resources" style="color: var(--text-muted); text-decoration: none;">Resources</a> /
      </div>
      <h1 style="font-size: 2rem; font-weight: 800; color: var(--text-primary);">Parenting Resources</h1>
      <p style="font-size: 0.9375rem; color: var(--text-secondary); margin-top: 0.5rem;">
        Curated tools and reading for modern parents.
      </p>
    </div>

    <div style="display: flex; flex-direction: column; gap: 1.25rem;">
      {[
        {
          category: "Family Organization",
          items: [
            { title: "How to build a weekly family routine that actually sticks", href: "/resources/blog/best-family-organizer-app-switzerland" },
            { title: "Shared calendars: why one source of truth matters", href: "/resources/blog/best-family-organizer-app-switzerland" },
          ]
        },
        {
          category: "Digital Wellbeing",
          items: [
            { title: "Screen time rules that work for the whole family", href: "/resources/blog" },
            { title: "Privacy-first tech for families: what to look for", href: "/resources/blog" },
          ]
        },
        {
          category: "Multilingual Families",
          items: [
            { title: "Raising bilingual children in Switzerland: practical tips", href: "/resources/blog" },
            { title: "Family apps that work in German, French, and Italian", href: "/resources/blog/familienplaner-app-schweiz-2025" },
          ]
        },
      ].map(section => (
        <div class="card" style="border-radius: 1.25rem; padding: 1.5rem;">
          <h2 style="font-size: 0.875rem; font-weight: 700; color: hsl(270 60% 72%); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 1rem;">{section.category}</h2>
          <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.75rem;">
            {section.items.map(item => (
              <li>
                <a href={item.href} style="font-size: 0.9375rem; color: var(--text-primary); text-decoration: none; display: flex; align-items: center; gap: 0.5rem;" class="hover:opacity-80">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="hsl(270 60% 65%)" stroke-width="2"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
                  {item.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="card" style="text-align: center; margin-top: 2rem; border-radius: 1.25rem; padding: 2rem;">
      <p style="font-size: 0.875rem; color: var(--text-secondary); margin-bottom: 1rem;">
        More resources coming weekly. Get notified when we publish.
      </p>
      <a href="https://app.eazy.family/onboarding" class="btn-primary" style="padding: 0.625rem 1.5rem; font-size: 0.875rem; border-radius: 0.75rem;">
        Join Eazy.Family Free
      </a>
    </div>

  </div>
</Layout>
