---
import Layout from '../../../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout
  title={post.data.title}
  description={post.data.description}
  lang="fr"
  article={{ headline: post.data.title, datePublished: post.data.pubDate.toISOString(), author: post.data.author }}
  langSwitcherOverride={{
    en: `/resources/blog/${post.id}`,
    de: `/de/resources/blog/${post.id}`,
    fr: `/fr/resources/blog/${post.id}`,
    it: `/it/resources/blog/${post.id}`,
  }}
>
  <article style="max-width: 44rem; margin: 0 auto; padding: 8rem 1.25rem 4rem;">
    <div style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 2rem;">
      <a href="/fr/resources" style="color: var(--text-muted); text-decoration: none;">Ressources</a> /
      <a href="/fr/resources/blog" style="color: var(--text-muted); text-decoration: none;"> Blog</a> /
    </div>
    <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.25rem;">
      {post.data.tags.map((tag: string) => (
        <span style="font-size: 0.6875rem; padding: 0.25rem 0.75rem; border-radius: 9999px; background: hsl(270 50% 18%); color: hsl(270 60% 80%); font-weight: 500;">{tag}</span>
      ))}
    </div>
    <h1 style="font-size: clamp(1.625rem, 4vw, 2.25rem); font-weight: 800; color: var(--text-primary); line-height: 1.25; margin-bottom: 1rem;">{post.data.title}</h1>
    <div style="display: flex; align-items: center; gap: 1rem; font-size: 0.8125rem; color: var(--text-muted); margin-bottom: 2.5rem; padding-bottom: 2rem; border-bottom: 1px solid hsl(270 40% 16%);">
      <span>{post.data.author}</span><span>·</span>
      <time>{post.data.pubDate.toLocaleDateString('fr-CH', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
    </div>
    <div class="prose" style="font-size: 1rem;"><Content /></div>
    <div class="card" style="text-align: center; margin-top: 4rem; border-radius: 1.25rem; padding: 2.5rem 2rem;">
      <h3 style="font-size: 1.25rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.625rem;">Prêt à organiser votre famille ?</h3>
      <p style="font-size: 0.875rem; color: var(--text-secondary); margin-bottom: 1.5rem;">Eazy.Family est gratuit. Aucun téléchargement requis.</p>
      <a href="https://app.eazy.family/onboarding" class="btn-primary">Commencer gratuitement</a>
    </div>
  </article>
</Layout>

<style>
  .prose :global(h2) { font-size: 1.375rem; font-weight: 700; margin: 2rem 0 0.75rem; }
  .prose :global(h3) { font-size: 1.125rem; font-weight: 600; margin: 1.5rem 0 0.5rem; }
  .prose :global(p) { margin-bottom: 1.25rem; }
  .prose :global(ul), .prose :global(ol) { padding-left: 1.5rem; margin-bottom: 1.25rem; }
  .prose :global(li) { margin-bottom: 0.375rem; }
  .prose :global(strong) { color: var(--text-primary); font-weight: 600; }
  .prose :global(a) { color: var(--purple); }
</style>
