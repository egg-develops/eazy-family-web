---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Eazy.Family – Privacy-First Family App for Switzerland" description="Eazy.Family is built for multilingual Swiss families. Learn our story, values, and why we believe family coordination should be private, simple, and ad-free.">

  <div style="position: fixed; top: -10rem; left: 50%; transform: translateX(-50%); width: 500px; height: 500px; border-radius: 50%; opacity: 0.15; background: radial-gradient(circle, hsl(270 88% 55%), transparent 70%); pointer-events: none; z-index: -1;"></div>

  <div style="max-width: 56rem; margin: 0 auto; padding: 8rem 1.25rem 4rem;">

    <!-- Mission -->
    <section style="text-align: center; max-width: 36rem; margin: 0 auto 5rem;">
      <h1 style="font-size: clamp(1.875rem, 5vw, 2.75rem); font-weight: 800; margin-bottom: 1.25rem;">
        <span class="grad-text">We're building a simple system<br />for day-to-day family life</span>
      </h1>
      <p style="font-size: 1rem; line-height: 1.75; color: var(--text-secondary);">
        Family life is full of moving parts — schedules, shopping, events, playdates, and constant communication. We built Eazy.Family to bring all of that into one private, calm space so families can spend less time managing and more time together.
      </p>
    </section>

    <!-- Values -->
    <section style="margin-bottom: 5rem;">
      <h2 style="font-size: 1.25rem; font-weight: 700; text-align: center; margin-bottom: 2rem; color: var(--text-primary);">Our values</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1rem;">
        {[
          { icon: "❤️", t: "Family First",       b: "Every decision we make starts with one question: does this make family life better?" },
          { icon: "🔒", t: "Privacy by Design",   b: "We never sell your data. Your family's information is encrypted and only accessible to you." },
          { icon: "👥", t: "Community Driven",    b: "Built with real parents — your feedback shapes every feature we build." },
          { icon: "⚡", t: "Eazy & Fast",          b: "The daily app for your family, we've taken great care to make it simple and useful." },
        ].map(v => (
          <div class="card" style="display: flex; gap: 1rem;">
            <div style="font-size: 1.5rem; flex-shrink: 0;">{v.icon}</div>
            <div>
              <h3 style="font-weight: 600; font-size: 0.9375rem; color: var(--text-primary); margin-bottom: 0.25rem;">{v.t}</h3>
              <p style="font-size: 0.8125rem; color: var(--text-secondary); line-height: 1.6;">{v.b}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Story -->
    <section style="max-width: 40rem; margin: 0 auto 5rem;">
      <h2 style="font-size: 1.25rem; font-weight: 700; color: var(--text-primary); margin-bottom: 1rem;">The story</h2>
      <p style="font-size: 0.9375rem; line-height: 1.8; color: var(--text-secondary); margin-bottom: 1rem;">
        Family life is beautiful. The days are long but the years are short and before you know it time has gone. Eazy.Family was built to make every moment count and remove the frustrations of daily life: too many apps and messaging channels, different calendars and separate shopping lists, searching for activities and events your children will enjoy. What's safe, what's not?
      </p>
      <p style="font-size: 0.9375rem; line-height: 1.8; color: var(--text-secondary);">
        Our goal was simple: one place, that's private and secure, helps you create lasting memories for your family and makes your daily life easier.
      </p>
    </section>

    <!-- CTA -->
    <section class="card" style="text-align: center; border-radius: 1.5rem; padding: 3rem 2rem;">
      <h2 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 0.75rem; color: var(--text-primary);">Join Eazy.Family</h2>
      <p style="font-size: 0.9375rem; color: var(--text-secondary); margin-bottom: 1.5rem;">No credit card required.</p>
      <a href="https://app.eazy.family/onboarding" class="btn-primary">Get Started Free</a>
    </section>

  </div>
</Layout>
