---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Family Events Switzerland – Local Activities for Kids & Families | Eazy.Family" description="Eazy.Family organizes real-world, age-appropriate events for Swiss families — music, arts, storytelling, outdoor adventures, and more. Sign up for free to stay updated.">

  <div style="position: fixed; top: -10rem; left: 50%; transform: translateX(-50%); width: 500px; height: 500px; border-radius: 50%; opacity: 0.15; background: radial-gradient(circle, hsl(270 88% 55%), transparent 70%); pointer-events: none; z-index: -1;"></div>

  <div style="max-width: 56rem; margin: 0 auto; padding: 8rem 1.25rem 4rem;">

    <!-- Hero -->
    <section style="text-align: center; max-width: 36rem; margin: 0 auto 4rem;">
      <div style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 500; background: hsl(270 50% 14% / 0.7); border: 1px solid hsl(270 40% 28%); color: hsl(270 60% 82%); margin-bottom: 1.5rem;">
        Your source for family-friendly events
      </div>
      <h1 style="font-size: clamp(1.875rem, 5vw, 2.75rem); font-weight: 800; margin-bottom: 1.25rem;">
        <span class="grad-text">Real-world events<br />for curious children</span>
      </h1>
      <p style="font-size: 1rem; line-height: 1.75; color: var(--text-secondary); margin-bottom: 2rem;">
        Eazy.Family organizes real-world, age-appropriate events designed to bring your family and friends together — music, arts, storytelling, outdoor adventures, and more.
      </p>
      <a href="https://app.eazy.family/onboarding" class="btn-primary">
        Join Eazy.Family for updates
      </a>
    </section>

    <!-- What to expect -->
    <section style="margin-bottom: 4rem;">
      <h2 style="font-size: 1.25rem; font-weight: 700; text-align: center; margin-bottom: 2rem; color: var(--text-primary);">What to expect</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1rem;">
        {[
          { icon: "🎵", t: "Music & Movement",    d: "Interactive sessions for babies and toddlers, concerts for young children." },
          { icon: "🎨", t: "Arts & Crafts",        d: "Creative workshops designed to spark imagination at every age." },
          { icon: "📖", t: "Storytelling",          d: "Live reading sessions and theatrical stories for the little ones." },
          { icon: "🌿", t: "Outdoor Adventures",   d: "Guided nature walks, scavenger hunts and outdoor play." },
        ].map(e => (
          <div class="card" style="display: flex; gap: 1rem;">
            <div style="font-size: 1.75rem; flex-shrink: 0;">{e.icon}</div>
            <div>
              <h3 style="font-weight: 600; font-size: 0.9375rem; color: var(--text-primary); margin-bottom: 0.25rem;">{e.t}</h3>
              <p style="font-size: 0.8125rem; color: var(--text-secondary); line-height: 1.6;">{e.d}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Stats -->
    <section style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 4rem; text-align: center;">
      {[
        { v: "Local",          l: "Events in your area" },
        { v: "Age appropriate", l: "From 6 months to age 10" },
        { v: "Calendar",       l: "Monthly and special events" },
      ].map(s => (
        <div class="card" style="border-radius: 1rem;">
          <div style="font-size: 1.125rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.25rem;">{s.v}</div>
          <div style="font-size: 0.75rem; color: var(--text-secondary);">{s.l}</div>
        </div>
      ))}
    </section>

    <!-- Coming soon CTA -->
    <section class="card" style="text-align: center; border-radius: 1.5rem; padding: 3rem 2rem;">
      <h2 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 0.75rem; color: var(--text-primary);">Events coming soon</h2>
      <p style="font-size: 0.9375rem; color: var(--text-secondary); margin-bottom: 1.5rem;">
        Create a free account to know when events are coming to your area.
      </p>
      <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center;">
        <a href="https://app.eazy.family/onboarding" class="btn-primary">Join Eazy.Family</a>
        <a href="https://app.eazy.family/onboarding" style="padding: 0.75rem 1.5rem; border-radius: 1rem; font-size: 1rem; color: hsl(270 40% 75%); text-decoration: none; display: inline-flex; align-items: center;">Explore the App</a>
      </div>
    </section>

  </div>
</Layout>
