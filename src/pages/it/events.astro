---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Eventi" description="Eazy.Family organizza eventi reali, appropriati all'età, pensati per riunire la tua famiglia e i tuoi amici — musica, arte, storie, avventure all'aperto e molto altro." lang="it">
  <div style="position: fixed; top: -10rem; left: 50%; transform: translateX(-50%); width: 500px; height: 500px; border-radius: 50%; opacity: 0.15; background: radial-gradient(circle, hsl(270 88% 55%), transparent 70%); pointer-events: none; z-index: -1;"></div>
  <div style="max-width: 56rem; margin: 0 auto; padding: 8rem 1.25rem 4rem;">
    <section style="text-align: center; max-width: 36rem; margin: 0 auto 4rem;">
      <div style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 500; background: hsl(270 50% 14% / 0.7); border: 1px solid hsl(270 40% 28%); color: hsl(270 60% 82%); margin-bottom: 1.5rem;">La tua fonte di eventi a misura di famiglia</div>
      <h1 style="font-size: clamp(1.875rem, 5vw, 2.75rem); font-weight: 800; margin-bottom: 1.25rem;"><span class="grad-text">Eventi reali<br />per bambini curiosi</span></h1>
      <p style="font-size: 1rem; line-height: 1.75; color: var(--text-secondary); margin-bottom: 2rem;">Eazy.Family organizza eventi reali, appropriati all'età, pensati per riunire la tua famiglia e i tuoi amici — musica, arte, storie, avventure all'aperto e molto altro.</p>
      <a href="https://app.eazy.family/onboarding" class="btn-primary">Unisciti a Eazy.Family per aggiornamenti</a>
    </section>
    <section style="margin-bottom: 4rem;">
      <h2 style="font-size: 1.25rem; font-weight: 700; text-align: center; margin-bottom: 2rem; color: var(--text-primary);">Cosa aspettarti</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1rem;">
        {[
          { icon: "🎵", t: "Musica & Movimento",        d: "Sessioni interattive per neonati e bambini piccoli, concerti per i più grandi." },
          { icon: "🎨", t: "Arti & Artigianato",         d: "Laboratori creativi progettati per stimolare la fantasia ad ogni età." },
          { icon: "📖", t: "Storie",                      d: "Letture dal vivo e storie teatrali per i più piccoli." },
          { icon: "🌿", t: "Avventure all'aperto",       d: "Passeggiate guidate nella natura, cacce al tesoro e giochi all'aperto." },
        ].map(e => (
          <div class="card" style="display: flex; gap: 1rem;">
            <div style="font-size: 1.75rem; flex-shrink: 0;">{e.icon}</div>
            <div><h3 style="font-weight: 600; font-size: 0.9375rem; color: var(--text-primary); margin-bottom: 0.25rem;">{e.t}</h3><p style="font-size: 0.8125rem; color: var(--text-secondary); line-height: 1.6;">{e.d}</p></div>
          </div>
        ))}
      </div>
    </section>
    <section class="card" style="text-align: center; border-radius: 1.5rem; padding: 3rem 2rem;">
      <h2 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 0.75rem; color: var(--text-primary);">Eventi in arrivo</h2>
      <p style="font-size: 0.9375rem; color: var(--text-secondary); margin-bottom: 1.5rem;">Crea un account gratuito per sapere quando gli eventi arriveranno nella tua zona.</p>
      <a href="https://app.eazy.family/onboarding" class="btn-primary">Unisciti a Eazy.Family</a>
    </section>
  </div>
</Layout>
