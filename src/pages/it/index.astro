---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Un posto Eazy per la tua famiglia" description="Calendari condivisi, liste di cose da fare, messaggi ed eventi per bambini — tutto in uno spazio sicuro costruito per la tua famiglia." lang="it">
  <div style="position: fixed; inset: 0; pointer-events: none; overflow: hidden; z-index: -1;">
    <div style="position: absolute; top: -10rem; left: 50%; transform: translateX(-50%); width: 600px; height: 600px; border-radius: 50%; opacity: 0.18; background: radial-gradient(circle, hsl(270 88% 55%), transparent 70%);"></div>
  </div>
  <section style="padding: 8rem 1.25rem 5rem; text-align: center;">
    <div style="max-width: 48rem; margin: 0 auto;">
      <div style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 500; background: hsl(270 50% 14% / 0.7); border: 1px solid hsl(270 40% 28%); color: hsl(270 60% 82%); margin-bottom: 1.5rem;">✦ iOS e Android disponibili presto</div>
      <h1 style="font-size: clamp(2.25rem, 6vw, 3.75rem); font-weight: 800; letter-spacing: -0.02em; line-height: 1.08; margin-bottom: 1.25rem;"><span class="grad-text">Un posto Eazy<br />per la tua famiglia</span></h1>
      <p style="font-size: 1.125rem; max-width: 32rem; margin: 0 auto 2rem; line-height: 1.7; color: var(--text-secondary);">Calendari condivisi, liste di cose da fare, messaggi ed eventi per bambini — tutto in uno spazio sicuro costruito per la tua famiglia.</p>
      <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center; margin-bottom: 1.5rem;">
        <a href="https://app.eazy.family/onboarding" class="btn-primary">Inizia — È gratuito <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14m-7-7 7 7-7 7"/></svg></a>
        <a href="https://app.eazy.family/auth" style="padding: 0.75rem 2rem; border-radius: 1rem; font-size: 1rem; color: hsl(270 40% 75%); text-decoration: none; display: inline-flex; align-items: center;">Accedi</a>
      </div>
      <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 1.25rem; font-size: 0.75rem; color: hsl(270 30% 55%);">
        {["Privato", "Sicuro", "Sincronizzazione multi-dispositivo"].map(t => (
          <span style="display: flex; align-items: center; gap: 0.4rem;"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="hsl(270 60% 72%)" stroke-width="2.5"><path d="M20 6 9 17l-5-5"/></svg>{t}</span>
        ))}
      </div>
    </div>
  </section>
  <section style="padding: 5rem 1.25rem;">
    <div style="max-width: 72rem; margin: 0 auto;">
      <h2 style="text-align: center; font-size: 1.75rem; font-weight: 700; margin-bottom: 3rem; color: var(--text-primary);">Tutto ciò di cui la tua famiglia ha bisogno</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem;">
        {[
          { icon: "🔒", title: "Sicuro e Privato",              desc: "I dati della tua famiglia sono tuoi. Crittografia TLS e controlli di accesso rigorosi." },
          { icon: "✨", title: "Assistente Eazy",                desc: "Il tuo assistente IA personale con funzionalità vocali per gestire la vita familiare a mani libere." },
          { icon: "📅", title: "Calendari e Liste condivisi",   desc: "Sincronizza orari, attività e liste della spesa istantaneamente su tutti i dispositivi." },
          { icon: "💬", title: "Messaggi di famiglia",           desc: "Uno spazio privato perché la tua famiglia rimanga connessa ogni giorno." },
          { icon: "👥", title: "Community di genitori",         desc: "Connettiti con i genitori vicini, condividi consigli e organizza incontri." },
          { icon: "📍", title: "Scopri eventi locali",          desc: "Trova attività ed eventi a misura di famiglia vicino a te." },
        ].map(f => (
          <div class="card" style="display: flex; gap: 1rem; align-items: flex-start;">
            <div style="width: 2.5rem; height: 2.5rem; flex-shrink: 0; border-radius: 0.75rem; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; background: linear-gradient(135deg, hsl(270 88% 58%), hsl(290 80% 62%));">{f.icon}</div>
            <div><h3 style="font-weight: 600; font-size: 0.9375rem; color: var(--text-primary); margin-bottom: 0.25rem;">{f.title}</h3><p style="font-size: 0.8125rem; color: var(--text-secondary); line-height: 1.6;">{f.desc}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>
  <section style="padding: 5rem 1.25rem;">
    <div class="card" style="max-width: 40rem; margin: 0 auto; text-align: center; border-radius: 1.5rem; padding: 3rem 2rem;">
      <h2 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 0.75rem; color: var(--text-primary);">Disponibile su tutti i tuoi dispositivi</h2>
      <p style="font-size: 0.9375rem; color: var(--text-secondary); margin-bottom: 2rem; line-height: 1.6;">Usa l'app web ora — le app native iOS e Android arriveranno presto.</p>
      <a href="https://app.eazy.family/onboarding" class="btn-primary">Inizia gratis</a>
      <p style="margin-top: 1rem; font-size: 0.75rem; color: var(--text-muted);">Gratuito · Senza pubblicità</p>
    </div>
  </section>
</Layout>
