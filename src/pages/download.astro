---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Download Eazy.Family – Free Family Organizer App" description="Get Eazy.Family free — the family organizer app for Switzerland. Shared calendar, tasks, chat, and AI assistant. Web app live now, iOS and Android apps coming soon.">

  <div style="position: fixed; top: -10rem; left: 50%; transform: translateX(-50%); width: 500px; height: 500px; border-radius: 50%; opacity: 0.15; background: radial-gradient(circle, hsl(270 88% 55%), transparent 70%); pointer-events: none; z-index: -1;"></div>

  <div style="max-width: 40rem; margin: 0 auto; padding: 8rem 1.25rem 4rem; text-align: center;">

    <h1 style="font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; margin-bottom: 1rem;">
      <span class="grad-text">Get Eazy.Family</span>
    </h1>
    <p style="font-size: 1rem; color: var(--text-secondary); margin-bottom: 3rem; line-height: 1.7;">
      Available on web now. Native iOS and Android apps are on the way.
    </p>

    <div style="display: flex; flex-direction: column; gap: 1rem; align-items: center; max-width: 20rem; margin: 0 auto 3rem;">

      <!-- Web App (active) -->
      <a href="https://app.eazy.family/onboarding" class="btn-primary" style="width: 100%; justify-content: center;">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        Open Web App
      </a>

      <!-- App Store (coming soon) -->
      <div style="width: 100%; display: flex; align-items: center; justify-content: center; gap: 0.75rem; padding: 0.875rem 1.5rem; border-radius: 0.875rem; border: 1px solid hsl(270 40% 22%); background: hsl(270 50% 10% / 0.6); opacity: 0.5; cursor: not-allowed; font-size: 0.9375rem; color: hsl(270 40% 78%);">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20.94c1.5 0 2.75 1.06 4 1.06 3 0 6-8 6-12.22A4.91 4.91 0 0 0 17 5c-2.22 0-4 1.44-5 2-1-.56-2.78-2-5-2a4.9 4.9 0 0 0-5 4.78C2 13.92 5 22 8 22c1.25 0 2.5-1.06 4-1.06z"/><path d="M10 2c0 2.5-2 3.5-2 5"/></svg>
        iOS App — Coming Soon
      </div>

      <!-- Google Play (coming soon) -->
      <div style="width: 100%; display: flex; align-items: center; justify-content: center; gap: 0.75rem; padding: 0.875rem 1.5rem; border-radius: 0.875rem; border: 1px solid hsl(270 40% 22%); background: hsl(270 50% 10% / 0.6); opacity: 0.5; cursor: not-allowed; font-size: 0.9375rem; color: hsl(270 40% 78%);">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M12 18h.01"/></svg>
        Android App — Coming Soon
      </div>
    </div>

    <div class="card" style="text-align: left; border-radius: 1.25rem;">
      <h3 style="font-weight: 600; font-size: 1rem; color: var(--text-primary); margin-bottom: 1rem;">Everything's available on web right now</h3>
      <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.625rem;">
        {[
          "Full cross-device sync",
          "Shared calendars & to-do lists",
          "Family messaging",
          "Local event discovery",
          "AI-powered Eazy Assistant",
          "Install as PWA from your browser",
        ].map(item => (
          <li style="display: flex; align-items: flex-start; gap: 0.625rem; font-size: 0.875rem; color: var(--text-secondary);">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="hsl(270 60% 72%)" stroke-width="2.5" style="margin-top: 1px; flex-shrink: 0;"><path d="M20 6 9 17l-5-5"/></svg>
            {item}
          </li>
        ))}
      </ul>
    </div>

    <div class="card" style="text-align: center; margin-top: 1.5rem; border-radius: 1.25rem;">
      <h3 style="font-weight: 600; font-size: 1rem; color: var(--text-primary); margin-bottom: 0.5rem;">Get notified when the apps launch</h3>
      <p style="font-size: 0.875rem; color: var(--text-secondary); margin-bottom: 1rem;">Create a free account and we'll email you when iOS and Android apps are ready.</p>
      <a href="https://app.eazy.family/onboarding" class="btn-primary" style="padding: 0.625rem 1.5rem; font-size: 0.875rem; border-radius: 0.75rem;">Create Free Account</a>
    </div>

  </div>
</Layout>
