---
import '../styles/global.css';

interface FaqItem {
  question: string;
  answer: string;
}

interface ArticleMeta {
  headline: string;
  datePublished: string;
  dateModified?: string;
  author?: string;
}

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  lang?: string;
  faqItems?: FaqItem[];
  article?: ArticleMeta;
}

const {
  title,
  description = "The AI-powered family organizer. Calendar, tasks, chat and more — private, multilingual, and beautifully simple.",
  ogImage = "/og-image.png",
  lang = "en",
  faqItems,
  article,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Detect current locale from URL
const path = Astro.url.pathname;
const currentLang = path.startsWith('/de') ? 'de' : path.startsWith('/fr') ? 'fr' : path.startsWith('/it') ? 'it' : 'en';

// Strip locale prefix to get the base path for lang switching
const basePath = path.replace(/^\/(de|fr|it)/, '') || '/';

const navLinks = [
  { href: currentLang === 'en' ? '/'         : `/${currentLang}/`,         label: currentLang === 'de' ? 'Start' : currentLang === 'fr' ? 'Accueil' : currentLang === 'it' ? 'Home' : 'Home' },
  { href: currentLang === 'en' ? '/about'    : `/${currentLang}/about`,    label: currentLang === 'de' ? 'Über uns' : currentLang === 'fr' ? 'À propos' : currentLang === 'it' ? 'Chi siamo' : 'About' },
  { href: currentLang === 'en' ? '/events'   : `/${currentLang}/events`,   label: currentLang === 'de' ? 'Events' : currentLang === 'fr' ? 'Événements' : currentLang === 'it' ? 'Eventi' : 'Events' },
  { href: currentLang === 'en' ? '/download' : `/${currentLang}/download`, label: currentLang === 'de' ? 'App laden' : currentLang === 'fr' ? 'Télécharger' : currentLang === 'it' ? "Scarica l'app" : 'Get the App' },
];

const langs = [
  { code: 'en', flag: '🇬🇧', label: 'EN', href: basePath },
  { code: 'de', flag: '🇩🇪', label: 'DE', href: `/de${basePath === '/' ? '' : basePath}` },
  { code: 'fr', flag: '🇫🇷', label: 'FR', href: `/fr${basePath === '/' ? '' : basePath}` },
  { code: 'it', flag: '🇮🇹', label: 'IT', href: `/it${basePath === '/' ? '' : basePath}` },
];

const ctaHref = currentLang === 'en' ? 'https://app.eazy.family/onboarding' : 'https://app.eazy.family/onboarding';
const ctaLabel = currentLang === 'de' ? 'Kostenlos starten' : currentLang === 'fr' ? 'Commencer gratuitement' : currentLang === 'it' ? 'Inizia gratis' : 'Get Started Free';
---

<!doctype html>
<html lang={currentLang === 'de' ? 'de-CH' : currentLang === 'fr' ? 'fr-CH' : currentLang === 'it' ? 'it-CH' : 'en'}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Eazy.Family</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- OG -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={`${title} | Eazy.Family`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.site)} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@eazy_family" />

  <!-- Icons -->
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="apple-touch-icon" href="/logo.png" />

  <!-- hreflang -->
  <link rel="alternate" hreflang="en" href={new URL(basePath, Astro.site)} />
  <link rel="alternate" hreflang="de-CH" href={new URL(`/de${basePath === '/' ? '' : basePath}`, Astro.site)} />
  <link rel="alternate" hreflang="fr-CH" href={new URL(`/fr${basePath === '/' ? '' : basePath}`, Astro.site)} />
  <link rel="alternate" hreflang="it-CH" href={new URL(`/it${basePath === '/' ? '' : basePath}`, Astro.site)} />

  <!-- Schema.org: Organization -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://eazy.family/#organization",
        "name": "Eazy.Family",
        "url": "https://eazy.family",
        "logo": "https://eazy.family/logo.png",
        "sameAs": ["https://x.com/eazy_family"],
        "contactPoint": { "@type": "ContactPoint", "email": "hello@eazy.family", "contactType": "customer support" }
      },
      {
        "@type": "SoftwareApplication",
        "@id": "https://eazy.family/#app",
        "name": "Eazy.Family",
        "operatingSystem": "iOS, Android, Web",
        "applicationCategory": "LifestyleApplication",
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "CHF" },
        "description": "Family organizer app with shared calendar, to-do lists, messaging, and AI assistant. Private, secure, no ads.",
        "url": "https://eazy.family",
        "publisher": { "@id": "https://eazy.family/#organization" }
      },
      ...(faqItems && faqItems.length > 0 ? [{
        "@type": "FAQPage",
        "mainEntity": faqItems.map(f => ({
          "@type": "Question",
          "name": f.question,
          "acceptedAnswer": { "@type": "Answer", "text": f.answer }
        }))
      }] : []),
      ...(article ? [{
        "@type": "Article",
        "headline": article.headline,
        "datePublished": article.datePublished,
        "dateModified": article.dateModified ?? article.datePublished,
        "author": { "@type": "Organization", "name": article.author ?? "Eazy.Family Team", "@id": "https://eazy.family/#organization" },
        "publisher": { "@id": "https://eazy.family/#organization" },
        "image": new URL(ogImage, Astro.site),
        "url": canonicalURL
      }] : [])
    ]
  })} />
</head>

<body>
  <!-- Nav -->
  <header class="fixed top-0 left-0 right-0 z-50" style="background: rgb(14 11 26 / 0.85); backdrop-filter: blur(12px); border-bottom: 1px solid hsl(270 40% 16%);">
    <div class="max-w-6xl mx-auto px-5 h-16 flex items-center justify-between gap-4">
      <a href={currentLang === 'en' ? '/' : `/${currentLang}/`} class="flex items-center gap-2.5 flex-shrink-0">
        <img src="/logo.png" alt="Eazy.Family" width="28" height="28" style="border-radius: 6px;" />
        <span style="font-weight: 600; font-size: 0.95rem; color: hsl(270 40% 85%);">Eazy.Family</span>
      </a>

      <nav class="hidden md:flex items-center gap-6">
        {navLinks.map(l => (
          <a href={l.href} style="font-size: 0.875rem; color: hsl(270 30% 68%);" class="hover:opacity-80 transition-opacity">{l.label}</a>
        ))}
        <!-- Resources dropdown -->
        <div class="relative group">
          <button style="font-size: 0.875rem; color: hsl(270 30% 68%); display: flex; align-items: center; gap: 0.25rem; background: none; border: none; cursor: pointer;" class="hover:opacity-80 transition-opacity">
            {currentLang === 'de' ? 'Ressourcen' : currentLang === 'fr' ? 'Ressources' : currentLang === 'it' ? 'Risorse' : 'Resources'}
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="absolute top-full left-1/2 -translate-x-1/2 pt-3 hidden group-hover:block">
            <div class="card min-w-[180px] p-2 flex flex-col gap-1" style="border-radius: 0.75rem;">
              <a href="/resources/blog" class="px-3 py-2 rounded-lg text-sm hover:opacity-80" style="color: hsl(270 30% 75%);">Blog</a>
              <a href="/resources/parenting" class="px-3 py-2 rounded-lg text-sm hover:opacity-80" style="color: hsl(270 30% 75%);">
                {currentLang === 'de' ? 'Eltern-Ressourcen' : currentLang === 'fr' ? 'Ressources parentales' : currentLang === 'it' ? 'Risorse genitori' : 'Parenting Resources'}
              </a>
            </div>
          </div>
        </div>
      </nav>

      <div class="flex items-center gap-2">
        <!-- Language switcher -->
        <div class="flex items-center gap-0.5">
          {langs.map(l => (
            <a
              href={l.href}
              style={`font-size: 0.7rem; padding: 0.2rem 0.4rem; border-radius: 0.375rem; text-decoration: none; font-weight: 500; transition: opacity 0.15s; ${currentLang === l.code ? 'color: hsl(270 60% 82%); background: hsl(270 50% 18%);' : 'color: hsl(270 30% 55%);'}`}
              aria-label={`Switch to ${l.label}`}
            >
              {l.flag} {l.label}
            </a>
          ))}
        </div>
        <a href={ctaHref} class="btn-primary hidden md:inline-flex" style="padding: 0.5rem 1.25rem; font-size: 0.875rem; border-radius: 0.75rem;">
          {ctaLabel}
        </a>
      </div>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer style="border-top: 1px solid hsl(270 40% 16%); padding: 2.5rem 1.25rem; margin-top: 4rem;">
    <div class="max-w-6xl mx-auto" style="display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 1.5rem;">
      <a href={currentLang === 'en' ? '/' : `/${currentLang}/`} class="flex items-center gap-2.5">
        <img src="/logo.png" alt="Eazy.Family" width="28" height="28" style="border-radius: 6px;" />
        <span style="font-weight: 600; font-size: 0.875rem; color: hsl(270 40% 80%);">Eazy.Family</span>
      </a>
      <nav style="display: flex; flex-wrap: wrap; align-items: center; gap: 1.5rem 2rem; font-size: 0.75rem; color: hsl(270 30% 58%);">
        <a href={currentLang === 'en' ? '/about' : `/${currentLang}/about`} class="hover:opacity-80">{currentLang === 'de' ? 'Über uns' : currentLang === 'fr' ? 'À propos' : currentLang === 'it' ? 'Chi siamo' : 'About'}</a>
        <a href={currentLang === 'en' ? '/events' : `/${currentLang}/events`} class="hover:opacity-80">{currentLang === 'de' ? 'Events' : currentLang === 'fr' ? 'Événements' : currentLang === 'it' ? 'Eventi' : 'Events'}</a>
        <a href={currentLang === 'en' ? '/download' : `/${currentLang}/download`} class="hover:opacity-80">{currentLang === 'de' ? 'App laden' : currentLang === 'fr' ? 'Télécharger' : currentLang === 'it' ? "Scarica" : 'Download'}</a>
        <a href="/resources/blog" class="hover:opacity-80">Blog</a>
        <a href="/privacy" class="hover:opacity-80">Privacy Policy</a>
        <a href="/terms" class="hover:opacity-80">Terms</a>
        <a href="https://x.com/eazy_family" target="_blank" rel="noopener noreferrer" class="hover:opacity-80" aria-label="Eazy.Family on X">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      </nav>
      <p style="font-size: 0.75rem; color: hsl(270 30% 40%);">© {new Date().getFullYear()} Eazy.Family · Made in Switzerland 🇨🇭</p>
    </div>
  </footer>
</body>
</html>
